---
# Copy to ansible/group_vars/vault.yml and encrypt: ansible-vault encrypt ansible/group_vars/vault.yml
# vault.yml is gitignored. SSH public key path is libvirt.ssh.key_file in group_vars/all.yml, not here.
#
# Red Hat subscription (activation key) — required on RHEL guests when rhel_subscription_enabled: true in all.yml
# Obtain org ID and activation key from the Red Hat Customer Portal / Subscription Management.
# vault_rhel_org_id: "12345678"
# vault_rhel_activation_key: "your-activation-key-name"

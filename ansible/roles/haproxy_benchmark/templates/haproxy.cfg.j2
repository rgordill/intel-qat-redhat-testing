# Managed by Ansible — scenario {{ haproxy_scenario }} (see docs/ROUTER_ENV_MAPPING.md)
global
    log /dev/log    local0
    maxconn 50000
    tune.ssl.default-dh-param 2048
{% if qatbench_enable_qat | bool and haproxy_scenario | lower in ['c', 'e'] %}
# Intel QAT engine (requires openssl-qat / engine; validate with haproxy -vv)
    ssl-engine qatengine
{% endif %}

defaults
    mode http
    log     global
    option  httplog
    option  dontlognull
    timeout connect 5s
    timeout client  30s
    timeout server  30s
    timeout tunnel  1h

{% set s = haproxy_scenario | lower %}
{% if s == 'a' %}
frontend fe_main
    bind *:80
    default_backend be_nginx_http

backend be_nginx_http
    server nginx1 127.0.0.1:8080 check
{% elif s in ['b', 'c'] %}
frontend fe_main
    bind *:443 ssl crt {{ certs_role_dir }}/haproxy.pem alpn h2,http/1.1
    default_backend be_nginx_http

backend be_nginx_http
    server nginx1 127.0.0.1:8080 check
{% elif s in ['d', 'e'] %}
frontend fe_main
    bind *:443 ssl crt {{ certs_role_dir }}/haproxy.pem alpn h2,http/1.1
    default_backend be_nginx_tls

backend be_nginx_tls
    server nginx1 127.0.0.1:8443 ssl verify required ca-file {{ certs_role_dir }}/ca.crt alpn h2,http/1.1
{% else %}
# Unknown scenario — default to (a)
frontend fe_main
    bind *:80
    default_backend be_nginx_http

backend be_nginx_http
    server nginx1 127.0.0.1:8080 check
{% endif %}
